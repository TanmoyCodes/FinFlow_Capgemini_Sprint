# ============================================================
# FinFlow - Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All variables have safe defaults for local development.
# ============================================================

# =========================
# DATABASE (shared credentials)
# =========================
DB_USERNAME=root
DB_PASSWORD=TanmoyPass4

# =========================
# DATABASE URLs (per service)
# =========================
AUTH_DB_URL=jdbc:mysql://localhost:3306/finflow_auth_db
APP_DB_URL=jdbc:mysql://localhost:3306/finflow_app_db
DOC_DB_URL=jdbc:mysql://localhost:3306/finflow_doc_db

# =========================
# JPA
# =========================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# =========================
# JWT SECRET (MUST be >=32 characters, MUST match across all services)
# =========================
JWT_SECRET=mysecretkeymysecretkeymysecretkey

# =========================
# GATEWAY SECRET (internal header shared between gateway & microservices)
# =========================
GATEWAY_SECRET=my-secret-key

# =========================
# SERVICE PORTS
# =========================
EUREKA_PORT=8761
CONFIG_SERVER_PORT=8888
GATEWAY_PORT=8085
AUTH_SERVICE_PORT=8080
APP_SERVICE_PORT=8081
DOC_SERVICE_PORT=8082

# =========================
# EUREKA
# =========================
EUREKA_URL=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost

# =========================
# CONFIG SERVER
# =========================
CONFIG_SERVER_URL=http://localhost:8888
CONFIG_GIT_URI=https://github.com/TanmoyCodes/finflow-config

# =========================
# RABBITMQ
# =========================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# =========================
# REDIS
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================
# LOGGING
# =========================
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_NETTY=DEBUG

# =========================
# SONARQUBE (for analysis)
# =========================
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your-sonarqube-token-here
